{
  "name": "Tollbooth Sample",
  "server": "src/tollbooth_sample/server.py",
  "deployment": {
    "env": {
      "NEON_DATABASE_URL": "${NEON_DATABASE_URL}",
      "BTCPAY_HOST": "${BTCPAY_HOST}",
      "BTCPAY_API_KEY": "${BTCPAY_API_KEY}",
      "BTCPAY_STORE_ID": "${BTCPAY_STORE_ID}",
      "SEED_BALANCE_SATS": "25",
      "CREDIT_TTL_SECONDS": "604800",
      "TOLLBOOTH_NOSTR_OPERATOR_NSEC": "${TOLLBOOTH_NOSTR_OPERATOR_NSEC}",
      "CONSTRAINTS_ENABLED": "${CONSTRAINTS_ENABLED}",
      "CONSTRAINTS_CONFIG": "${CONSTRAINTS_CONFIG}"
    }
  }
}
